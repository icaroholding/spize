# Copy to .env and adjust as needed. .env is gitignored.

# aex-control-plane
DATABASE_URL=postgres://aex:aex_dev@localhost:5432/aex
BIND_ADDR=127.0.0.1:8080
AUDIT_LOG_PATH=./data/audit.jsonl
BLOB_DIR=./data/blobs
SIGNING_KEY_PATH=./data/signing-key.bin
MAX_TRANSFER_BYTES=524288000
# Comma-separated list of browser origins permitted to hit the control
# plane (e.g. `https://dashboard.spize.io`). Empty = same-origin only.
# `*` opens to any origin (dev only — logs a warning at boot).
CORS_ALLOWED_ORIGINS=
# `json` enables structured logs for production log aggregators. Any
# other value (or unset) uses the pretty text format.
LOG_FORMAT=text
RUST_LOG=info,aex_control_plane=debug,sqlx=warn
